{
  "name": "@clawlens/plugin",
  "version": "0.1.0",
  "description": "ClawLens OpenClaw plugin for observability and debugging",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "fixtures",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsup && npm run copy-fixtures",
    "copy-fixtures": "mkdir -p dist/fixtures && cp -r fixtures/demo dist/fixtures/",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "glob": "^10.3.10",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.25",
    "@vitest/coverage-v8": "^1.6.1",
    "openclaw": "^2026.3.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
