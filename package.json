{
  "name": "clawlens",
  "version": "0.1.0",
  "private": true,
  "description": "Investigation and debugging layer for OpenClaw",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:packages": "pnpm -r test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "dev:plugin": "pnpm --filter @clawlens/plugin dev",
    "dev:ui": "pnpm --filter @clawlens/ui dev",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "observability",
    "debugging",
    "investigation"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  }
}
